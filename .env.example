# OpenClaw環境変数テンプレート
# コピーして instances/alice/.env として使用
# chmod 600 instances/alice/.env

# UID/GID（コンテナ内のユーザー）
# macOS: 501:20（デフォルトユーザー:staff）
# Linux: 1000:1000（標準ユーザー）
CONTAINER_UID=1000
CONTAINER_GID=1000

# Anthropic API Key
# 取得: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Telegram Bot Token（オプション）
# 取得: @BotFather で /newbot
# 設定しない場合はTUI/WebChatのみ（localモード）
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz-ABCDEFGHI

# PostgreSQL接続（オプション）
# Mac Docker Desktop: host.docker.internal
# Linux: host-gateway または network_mode: host
DB_DSN=host=host.docker.internal dbname=bonsoleil user=teddy password=***

# ollama接続（オプション）
OLLAMA_URL=http://host.docker.internal:11434/api/embed
