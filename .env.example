# OpenClaw環境変数テンプレート
# コピーして instances/alice/.env として使用
# chmod 600 instances/alice/.env

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-api03-...

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=...

# PostgreSQL接続（オプション）
# Mac Docker Desktop: host.docker.internal
# Linux: host-gateway または network_mode: host
DB_DSN=host=host.docker.internal dbname=bonsoleil user=teddy password=***

# ollama接続（オプション）
OLLAMA_URL=http://host.docker.internal:11434/api/embed
